{
  "name": "@dakinfosystems/events",
  "version": "2.0.1",
  "description": "eventJS enables script to emit event so that subscriber of that event will be notified.",
  "type": "module",
  "main": "dist/events.js",
  "module": "dist/index.js",
  "types": "dist/@types/index.d.ts",
  "unpkg": "dist/events.js",
  "jsdelivr": "dist/events.js",
  "exports": {
    "types": "./dist/@types/index.d.ts",
    "import": "./dist/index.js",
    "require": "./dist/index.cjs",
    "default": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "test:vitest": "vitest run",
    "test": "pnpm run test:vitest",
    "test:gh": "npm run test:vitest",
    "build:tsup": "tsup && shx mv dist/index.global.js dist/events.js && shx mv dist/index.global.js.map dist/events.js.map",
    "build:types": "tsc -p tsconfig.types.json",
    "build": "pnpm run build:tsup && pnpm run build:types",
    "build:gh": "npm run build:tsup && npm run build:types",
    "clean": "shx rm -rf dist/*",
    "start:karma": "karma start --no-single-run --browsers ChromeHeadless,FirefoxHeadless karma.conf.js",
    "test:karma": "karma start --single-run --browsers ChromeHeadless karma.conf.js",
    "test:karmawatch": "karma start --auto-watch --no-single-run --browsers ChromeHeadless,FirefoxHeadless karma.conf.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pramodaug17/eventJS.git"
  },
  "keywords": [
    "eventjs"
  ],
  "author": "Pramod Jain",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/pramodaug17/eventJS/issues"
  },
  "homepage": "https://github.com/pramodaug17/eventJS#readme",
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.5",
    "chai": "^6.2.2",
    "esbuild": "^0.28.0",
    "fancy-log": "^2.0.0",
    "jsdom": "^29.0.2",
    "karma": "^6.4.4",
    "karma-chai": "^0.1.0",
    "karma-chrome-launcher": "^3.2.0",
    "karma-esbuild": "^2.3.0",
    "karma-firefox-launcher": "^2.1.3",
    "karma-mocha": "^2.0.1",
    "mocha": "^11.7.5",
    "shx": "^0.4.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
